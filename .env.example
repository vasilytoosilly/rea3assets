# ---------------------------------------------------------------------------
# ReA3 Asset Manager — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values for your environment.

# PostgreSQL connection string for the asset manager database.
# This is a SEPARATE database from the ERP — do not use the ERP's database URL.
# Create the database first:  psql -c "CREATE DATABASE rea3_assets;"
ASSET_DB_URL=postgresql://postgres:postgres@localhost:5432/rea3_assets?schema=public

# Admin password for the admin UI.
# When set, all admin pages and API routes require authentication.
# When unset (or NODE_ENV=development), auth is disabled for local dev.
# ADMIN_PASSWORD=change-me-to-a-strong-password

# ERP internal API key — used for SKU sync calls to the core ERP.
# Must match a key configured on the rea3erp side.
# ERP_INTERNAL_API_KEY=your-erp-api-key

# Base URL of the core ERP (rea3erp).
# Used for SKU sync, asset sync, and health checks.
ERP_INTERNAL_URL=http://localhost:3000

# Directory for uploaded files (local filesystem storage).
# Defaults to ./uploads if not set. Use an absolute path for production.
# UPLOAD_DIR=./uploads

# Maximum upload file size in megabytes (default 50).
# UPLOAD_MAX_MB=50

# ---------------------------------------------------------------------------
# ERP client tuning (optional — sensible defaults are built in)
# ---------------------------------------------------------------------------
# ERP_RETRY_MAX=3
# ERP_RETRY_BASE_DELAY_MS=200
# ERP_REQUEST_TIMEOUT_MS=10000
# ERP_CB_THRESHOLD=5
# ERP_CB_COOLDOWN_MS=30000

# ---------------------------------------------------------------------------
# Marketplace / website integration (optional)
# ---------------------------------------------------------------------------
# Public URL of the ERP storefront, used for "Buy" / "Get This Asset" links
# on the marketplace product pages. When unset, buy buttons are disabled.
# NEXT_PUBLIC_ERP_URL=https://shop.rea3.studio
